void calculator() {
    double num, num2, result;
    char operation;

    cout << "Welcome to world's simplest calculator!\n\n";

    while (true) {
        cout << "Select operation (+, -, *, /) or 'q' to quit: ";
        cin >> operation;

        if (operation == 'q' || operation == 'Q') break;
        if (operation != '+' && operation != '-' && operation != '*' && operation != '/') {
            cout << " Invalid operation! Try again.\n\n";
            continue;
        }

        cout << "Enter 1st number: ";
        cin >> num;
        cout << "Enter 2nd number: ";
        cin >> num2;

        switch (operation) {
            case '+': result = num + num2; break;
            case '-': result = num - num2; break;
            case '*': result = num * num2; break;
            case '/':
                if (num2 == 0) {
                    cout << "Cannot divide by zero!\n\n";
                    continue;
                }
                result = num / num2;
                break;
        }

        cout << "Result: " << num << " " << operation << " " << num2 << " = " << result << "\n\n";
        cout << "Press Enter to continue or 'q' + Enter to quit: ";
        cin.ignore();
        cin.get();
    }
    cout << "Thanks for using calculator!\n";
}


